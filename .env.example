# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase credentials
# Get these values from: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# RAZORPAY PAYMENT GATEWAY
# ===========================================
# Get these from https://dashboard.razorpay.com/app/keys
# Use test keys for development (rzp_test_xxx)
# Use live keys for production (rzp_live_xxx)

# Frontend (public key - safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Backend only (add to Supabase Edge Function secrets)
# NEVER expose this in frontend code!
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# ===========================================
# SUPABASE EDGE FUNCTION SECRETS
# ===========================================
# Add these secrets via Supabase Dashboard:
# 1. Go to Project Settings → Edge Functions
# 2. Add secrets:
#    - RAZORPAY_KEY_ID: your Razorpay Key ID
#    - RAZORPAY_KEY_SECRET: your Razorpay Key Secret
