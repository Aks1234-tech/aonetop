# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase credentials
# Get these values from: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# RAZORPAY PAYMENT GATEWAY
# ===========================================
# Get these from https://dashboard.razorpay.com/app/keys
# Use test keys for development (rzp_test_xxx)
# Use live keys for production (rzp_live_xxx)

# Frontend (public key - safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Backend only (add to Supabase Edge Function secrets)
# NEVER expose this in frontend code!
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# ===========================================
# SUPABASE EDGE FUNCTION SECRETS
# ===========================================
# Add these secrets via Supabase Dashboard:
# 1. Go to Project Settings → Edge Functions
# 2. Add secrets:
#    - RAZORPAY_KEY_ID: your Razorpay Key ID
#    - RAZORPAY_KEY_SECRET: your Razorpay Key Secret

# ============================================================================
# NOTIFICATION SYSTEM ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# These are required for the notification system to function

# ============================================================================
# EMAIL SERVICE (Gmail SMTP)
# ============================================================================
# Gmail Setup Instructions:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select Mail and Windows Computer (or your device)
# 3. Copy the generated 16-character password
# 4. Save it in GMAIL_APP_PASSWORD below

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
REPLY_TO_EMAIL=noreply@aonetop.com

# Optional: For SendGrid (production)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@aonetop.com

# ============================================================================
# SMS SERVICE (Twilio)
# ============================================================================
# Twilio Setup Instructions:
# 1. Sign up at https://www.twilio.com
# 2. Get Account SID and Auth Token from console
# 3. Purchase a phone number
# 4. Enable WhatsApp (optional)
# 5. Copy credentials below

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# ============================================================================
# DATABASE (Supabase)
# ============================================================================
# Already configured in existing .env files
# But needed for notification system:

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (BACKEND ONLY - Never expose to client!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

NODE_ENV=development

# Notification Settings
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=5000
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_QUEUE_POLL_INTERVAL_MS=30000

# Rate Limiting
NOTIFICATION_MAX_PER_DAY=50
NOTIFICATION_MAX_PER_HOUR=10

# Quiet Hours (optional)
NOTIFICATION_QUIET_HOURS_START=22:00
NOTIFICATION_QUIET_HOURS_END=08:00

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=info
DEBUG_NOTIFICATIONS=false

# ============================================================================
# DEPLOYMENT
# ============================================================================

PRODUCTION_URL=https://aonetop.com
STAGING_URL=https://staging.aonetop.com
